<!DOCTYPE html>
<!--
  主題 {{NUM}} · {{NAME}} — 教學文件（由 new-topic skill 產生的骨架）
  CLAUDE：依 課程規劃.md 與 001-變數與型別/教學.html，把下方每個「<!-- CLAUDE 填 … -->」補完。
  規則：每個 sample 對應一個 .topic 群組；章節與 sample 註解一一對應；
        callout 用 key/conv/trap/analogy；程式碼裡 < > & 要 escape（&lt; &gt; &amp;）。
  純前端、自包含、繁中；HTML 註解不可巢狀。
-->
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{NUM}} · {{NAME}}</title>
<style>
  :root{--go-cyan:#00ADD8;--go-cyan-dark:#007d9c;--ink:#1c2733;--muted:#5b6b7a;--bg:#f6f8fa;--card:#fff;--border:#e1e8ed;--code-bg:#0f1720;--code-ink:#e6edf3}
  *{box-sizing:border-box}
  body{margin:0;font-family:-apple-system,"PingFang TC","Microsoft JhengHei","Segoe UI",system-ui,sans-serif;color:var(--ink);background:var(--bg);line-height:1.75}
  header{background:linear-gradient(135deg,var(--go-cyan) 0%,var(--go-cyan-dark) 100%);color:#fff;padding:30px 24px 24px}
  header .wrap{max-width:940px;margin:0 auto}
  header .crumb{font-size:13px;opacity:.9;margin-bottom:8px}
  header .crumb a{color:#fff;text-decoration:none;border-bottom:1px dotted rgba(255,255,255,.6)}
  header h1{margin:0 0 6px;font-size:26px;letter-spacing:.5px}
  header p{margin:0;opacity:.92;font-size:14.5px}
  nav{position:sticky;top:0;z-index:10;background:rgba(255,255,255,.93);backdrop-filter:blur(6px);border-bottom:1px solid var(--border)}
  nav .wrap{max-width:940px;margin:0 auto;padding:10px 24px;display:flex;flex-wrap:wrap;gap:8px}
  nav a{text-decoration:none;color:var(--go-cyan-dark);font-size:13.5px;font-weight:600;padding:5px 12px;border-radius:999px;background:#eaf7fb}
  nav a:hover{background:var(--go-cyan);color:#fff}
  main{max-width:940px;margin:0 auto;padding:26px 24px 80px}
  .overview{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:8px 8px 4px;margin-bottom:28px;overflow-x:auto}
  .overview h2{margin:14px 16px 0}
  .mermaid{text-align:center}
  .topic{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:22px 24px;margin-bottom:22px;box-shadow:0 1px 2px rgba(16,40,64,.04)}
  .topic>h2{margin:0 0 4px;font-size:21px;display:flex;align-items:center;gap:10px}
  .topic>h2 .tag{font-size:12px;font-weight:700;color:#fff;background:var(--go-cyan);padding:2px 10px;border-radius:999px;letter-spacing:.5px}
  .topic h3{margin:24px 0 10px;font-size:16.5px;color:var(--go-cyan-dark);border-left:4px solid var(--go-cyan);padding-left:10px}
  .maplink{font-size:12.5px;color:var(--muted);margin:-2px 0 10px;padding-left:14px}
  .maplink code{background:#eef2f5}
  code{font-family:"SF Mono","JetBrains Mono",Menlo,Consolas,monospace;background:#eef2f5;color:#b03a5b;padding:1px 6px;border-radius:5px;font-size:.9em}
  pre{background:var(--code-bg);color:var(--code-ink);padding:14px 16px;border-radius:10px;overflow-x:auto;font-family:"SF Mono","JetBrains Mono",Menlo,Consolas,monospace;font-size:13.5px;line-height:1.6}
  pre code{background:none;color:inherit;padding:0}
  .cmt{color:#6b8a99}
  table{border-collapse:collapse;width:100%;margin:14px 0;font-size:14.5px}
  th,td{border:1px solid var(--border);padding:9px 12px;text-align:left;vertical-align:top}
  th{background:#eef6f9}
  tbody tr:nth-child(even){background:#fafcfd}
  .callout{border-radius:10px;padding:12px 16px;margin:14px 0;border-left:5px solid;font-size:14.5px}
  .callout strong{display:inline-block;margin-right:6px}
  .key{background:#eafaf1;border-color:#2ecc71}
  .conv{background:#eef4ff;border-color:#4a8cff}
  .trap{background:#fff3ea;border-color:#ff8c42}
  .analogy{background:#f4eeff;border-color:#9b6dff}
  footer{text-align:center;color:var(--muted);font-size:13px;padding:24px}
</style>
</head>
<body>

